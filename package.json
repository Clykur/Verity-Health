{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "workspaces": ["artifacts/*", "lib/*", "scripts"],
  "scripts": {
    "dev": "PORT=${PORT:-5173} BASE_PATH=${BASE_PATH:-/} npm run dev -w @workspace/clinic-website",
    "dev:clinic": "npm run dev",
    "dev:mockup": "PORT=${PORT:-5173} BASE_PATH=${BASE_PATH:-/} npm run dev -w @workspace/mockup-sandbox",
    "dev:api": "npm run dev -w @workspace/api-server",
    "build": "npm run typecheck && npm run build --workspaces --if-present",
    "typecheck:libs": "tsc --build",
    "typecheck": "npm run typecheck:libs && npm run typecheck --workspaces --if-present"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  },
  "overrides": {
    "@esbuild-kit/esm-loader": "npm:tsx@^4.21.0",
    "esbuild": "0.27.3"
  }
}
